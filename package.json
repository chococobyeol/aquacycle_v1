{
  "name": "aquacycle",
  "productName": "AquaCycle",
  "version": "0.2.0",
  "description": "A doodle-style aquatic ecosystem simulation for Windows and macOS.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:release": "vitest run --pool=threads --poolOptions.threads.singleThread",
    "test:watch": "vitest",
    "verify:release": "npm run typecheck && npm run test:release && npm run verify:long-cycle",
    "verify:long-cycle": "vite-node scripts/verifyLongCycle.ts",
    "verify:day-night-performance": "vite-node scripts/verifyDayNightLightingPerformance.ts",
    "verify:worker-cadence": "vite-node scripts/verifyWorkerCadence.ts"
  },
  "dependencies": {
    "matter-js": "^0.20.0",
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.7",
    "electron": "^41.7.1",
    "typescript": "^7.0.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  }
}
